# Boardsesh Self-Hosted Configuration
# Copy this file to .env and fill in the required values.

# ──────────────────────────────────────────────
# Required Settings
# ──────────────────────────────────────────────

# Database credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=boardsesh

# Authentication secrets (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=changeme-generate-a-random-string
IRON_SESSION_PASSWORD=changeme-must-be-at-least-32-characters-long

# ──────────────────────────────────────────────
# URL Configuration
# ──────────────────────────────────────────────

# URL where the app is accessible (change for remote/domain access)
NEXTAUTH_URL=http://localhost:3000

# WebSocket URL for real-time features (must be reachable from the browser)
# For local use: ws://localhost:8080/graphql
# For LAN access: ws://YOUR_SERVER_IP:8080/graphql
# For domain with SSL: wss://ws.yourdomain.com/graphql
NEXT_PUBLIC_WS_URL=ws://localhost:8080/graphql

# ──────────────────────────────────────────────
# Port Configuration (optional)
# ──────────────────────────────────────────────

# WEB_PORT=3000
# BACKEND_PORT=8080

# ──────────────────────────────────────────────
# Optional: OAuth Providers
# ──────────────────────────────────────────────

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# APPLE_ID=
# APPLE_SECRET=

# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# ──────────────────────────────────────────────
# Optional: Email Verification
# ──────────────────────────────────────────────

# EMAIL_VERIFICATION_ENABLED=true
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@yourdomain.com

# ──────────────────────────────────────────────
# Optional: S3-compatible storage for avatars
# ──────────────────────────────────────────────

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_ENDPOINT_URL=
# AWS_S3_BUCKET_NAME=
